{
  "name": "z-packer",
  "type": "module",
  "version": "0.0.0",
  "packageManager": "pnpm@10.25.0",
  "description": "A CLI tool to compress code projects while strictly respecting your .gitignore.",
  "author": "OSpoon",
  "license": "MIT",
  "homepage": "https://github.com/OSpoon/z-packer#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OSpoon/z-packer.git"
  },
  "bugs": "https://github.com/OSpoon/z-packer/issues",
  "keywords": [],
  "sideEffects": false,
  "exports": {
    ".": "./dist/index.mjs",
    "./cli": "./dist/cli.mjs",
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.mts",
  "bin": {
    "z-packer": "./bin/z-packer.mjs"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lint": "eslint",
    "prepublishOnly": "nr build",
    "release": "bumpp",
    "start": "tsx src/index.ts",
    "test": "vitest",
    "typecheck": "tsc",
    "prepare": "simple-git-hooks"
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "chalk": "^5.6.2",
    "cli-progress": "^3.12.0",
    "cli-table3": "^0.6.5",
    "filesize": "^11.0.13",
    "fs-extra": "^11.3.3",
    "globby": "^14.1.0",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.2.0",
    "@antfu/ni": "^28.0.0",
    "@antfu/utils": "^9.3.0",
    "@types/archiver": "^6.0.3",
    "@types/cli-progress": "^3.11.6",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.0.1",
    "@types/yargs": "^17.0.35",
    "bumpp": "^10.3.2",
    "eslint": "^9.10.0",
    "lint-staged": "^16.2.7",
    "publint": "^0.3.16",
    "simple-git-hooks": "^2.13.1",
    "tinyexec": "^1.0.2",
    "tsdown": "^0.20.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.7",
    "vitest": "^3.0.0",
    "vitest-package-exports": "^0.1.1",
    "yaml": "^2.8.2"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm i --frozen-lockfile --ignore-scripts --offline && npx lint-staged"
  },
  "lint-staged": {
    "*": "eslint --fix"
  }
}
